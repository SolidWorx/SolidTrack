{% set modal_id = 'project-delete-' ~ project.id %}
{% set time_entry_count = project.timeEntries|length %}

<button type="button" class="btn btn-link text-danger p-0 ms-3" data-bs-toggle="modal" data-bs-target="#{{ modal_id }}">
    {{ ux_icon('tabler:trash', {width: '16px', height: '16px'}) }}
    {{ 'Delete'|trans }}
</button>

<twig:Ui:Modal id="{{ modal_id }}" :title="'Delete project'|trans" status="danger" :centered="true">
    <p>
        {{ 'Are you sure you want to delete the project'|trans }}
        <strong>{{ project.name }}</strong>?
    </p>
    {% if time_entry_count > 0 %}
        <div class="alert alert-warning mb-0 d-flex align-items-start gap-2">
            {{ ux_icon('tabler:alert-triangle', {width: '20px', height: '20px'}) }}
            <div>
                {{ 'This will also permanently delete %count% associated time %entries%.'|trans({
                    '%count%': time_entry_count,
                    '%entries%': time_entry_count == 1 ? 'entry'|trans : 'entries'|trans,
                }) }}
                {{ 'This action cannot be undone.'|trans }}
            </div>
        </div>
    {% else %}
        <p class="text-muted mb-0">{{ 'This action cannot be undone.'|trans }}</p>
    {% endif %}

    <twig:block name="footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
        <form method="post" action="{{ path('app_project_delete', {'id': project.id}) }}" class="d-inline">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ project.id) }}">
            <button type="submit" class="btn btn-danger">
                {{ ux_icon('tabler:trash') }}
                {{ 'Delete project'|trans }}
            </button>
        </form>
    </twig:block>
</twig:Ui:Modal>
