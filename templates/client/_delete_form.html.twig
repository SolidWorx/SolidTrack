{% set modal_id = 'client-delete-' ~ client.id %}
{% set project_count = client.projects|length %}
{% set time_entry_count = 0 %}
{% for project in client.projects %}
    {% set time_entry_count = time_entry_count + project.timeEntries|length %}
{% endfor %}

<button type="button" class="btn btn-link text-danger p-0 ms-3" data-bs-toggle="modal" data-bs-target="#{{ modal_id }}">
    {{ ux_icon('tabler:trash', {width: '16px', height: '16px'}) }}
    {{ 'Delete'|trans }}
</button>

<twig:Ui:Modal id="{{ modal_id }}" :title="'Delete client'|trans" status="danger" :centered="true">
    <p>
        {{ 'Are you sure you want to delete the client'|trans }}
        <strong>{{ client.name }}</strong>?
    </p>
    {% if project_count > 0 or time_entry_count > 0 %}
        <div class="alert alert-warning mb-0 d-flex align-items-start gap-2">
            {{ ux_icon('tabler:alert-triangle', {width: '20px', height: '20px'}) }}
            <div>
                {{ 'This will also permanently delete:'|trans }}
                <ul class="mb-0 mt-1">
                    {% if project_count > 0 %}
                        <li>{{ '%count% %projects%'|trans({
                            '%count%': project_count,
                            '%projects%': project_count == 1 ? 'project'|trans : 'projects'|trans,
                        }) }}</li>
                    {% endif %}
                    {% if time_entry_count > 0 %}
                        <li>{{ '%count% time %entries%'|trans({
                            '%count%': time_entry_count,
                            '%entries%': time_entry_count == 1 ? 'entry'|trans : 'entries'|trans,
                        }) }}</li>
                    {% endif %}
                </ul>
                <div class="mt-2">{{ 'This action cannot be undone.'|trans }}</div>
            </div>
        </div>
    {% else %}
        <p class="text-muted mb-0">{{ 'This action cannot be undone.'|trans }}</p>
    {% endif %}

    <twig:block name="footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
        <form method="post" action="{{ path('app_client_delete', {'id': client.id}) }}" class="d-inline">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ client.id) }}">
            <button type="submit" class="btn btn-danger">
                {{ ux_icon('tabler:trash') }}
                {{ 'Delete client'|trans }}
            </button>
        </form>
    </twig:block>
</twig:Ui:Modal>
