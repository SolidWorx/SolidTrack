<div {{ attributes }}>
    <div class="d-flex align-items-center justify-content-between" style="margin-bottom: 10px;">
        <h2 style="font-size: 15px; font-weight: 600; color: var(--st-text-primary); margin: 0; letter-spacing: -0.01em;">
            {{ 'Recent activity'|trans }}
        </h2>
        <a href="#" class="st-card-link">{{ 'View all entries →'|trans }}</a>
    </div>

    {% for date, trackers in userActivity %}
        <div class="st-card" style="margin-bottom: 14px; overflow: hidden;">
            <div class="st-day">
                <div class="date">
                    <b>{{ date }}</b>
                </div>
                <div class="total">
                    {{ 'Total'|trans }}
                    <b><time>{{ format_interval(trackers.total, true) }}</time></b>
                </div>
            </div>

            {% for tracker in trackers.entries %}
                <div class="st-row">
                    <div class="st-row-desc">
                        <div class="st-row-title">{{ tracker.description ?: ('(no description)'|trans) }}</div>
                        <div class="st-row-meta">
                            {% if tracker.project is not empty %}
                                <span class="st-pchip">
                                    <span class="st-pdot" style="background: {{ tracker.project.color }};"></span>
                                    <span>{{ tracker.project.name }}</span>
                                    {% if tracker.project.client %}
                                        <span class="client">· {{ tracker.project.client }}</span>
                                    {% endif %}
                                </span>
                            {% endif %}
                            {% for tag in tracker.tags %}
                                <span class="st-tagchip">{{ tag.name }}</span>
                            {% endfor %}
                        </div>
                    </div>

                    <div class="st-row-time">{{ tracker.dateStart.format('H:i') }}</div>

                    <div class="st-row-dur st-time">
                        <time>{{ format_interval(tracker.duration, true) }}</time>
                    </div>

                    <button type="button"
                            class="st-row-bill{{ tracker.billable ? ' on' : '' }}"
                            {{ live_action('toggleBillable', {id: tracker.id}) }}
                            title="{{ (tracker.billable ? 'Billable (click to mark non-billable)' : 'Non-billable (click to mark billable)')|trans }}"
                            aria-label="{{ (tracker.billable ? 'Billable' : 'Non-billable')|trans }}">
                        {{ ux_icon(tracker.billable ? 'tabler:currency-dollar' : 'tabler:currency-dollar-off', {'width': '16', 'height': '16'}) }}
                    </button>

                    <button type="button"
                            class="st-row-act danger"
                            data-action="live#action:prevent"
                            data-live-action-param="removeItem"
                            data-live-id-param="{{ tracker.id }}"
                            aria-label="{{ 'Delete entry'|trans }}"
                            title="{{ 'Delete entry'|trans }}">
                        {{ ux_icon('tabler:trash', {'width': '16', 'height': '16'}) }}
                    </button>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="st-card">
            <div class="st-card-body" style="padding: 32px 22px; text-align: center; color: var(--st-text-muted);">
                {{ 'No tracked time yet — start the timer above.'|trans }}
            </div>
        </div>
    {% endfor %}
</div>
