<div {{ attributes }}>
    <div class="card">
        <div class="card-header py-2">
            <h3 class="card-title">{{ 'This Week'|trans }}</h3>
            <div class="card-actions btn-list">
                <button type="button"
                        class="btn btn-sm btn-icon"
                        {{ live_action('previousWeek') }}
                        aria-label="{{ 'Previous week'|trans }}"
                        title="{{ 'Previous week'|trans }}">
                    {{ ux_icon('tabler:chevron-left', {'width': '16', 'height': '16'}) }}
                </button>
                <button type="button"
                        class="btn btn-sm"
                        {{ live_action('currentWeek') }}
                        {{ weekOffset == 0 ? 'disabled' : '' }}
                        title="{{ 'Jump to current week'|trans }}">
                    {{ rangeLabel }}
                </button>
                <button type="button"
                        class="btn btn-sm btn-icon"
                        {{ live_action('nextWeek') }}
                        aria-label="{{ 'Next week'|trans }}"
                        title="{{ 'Next week'|trans }}">
                    {{ ux_icon('tabler:chevron-right', {'width': '16', 'height': '16'}) }}
                </button>
            </div>
        </div>
        <div class="card-body">
            <div class="row text-center mb-3">
                <div class="col">
                    <div class="text-secondary small">{{ 'Total'|trans }}</div>
                    <div class="font-weight-medium"><time>{{ format_interval(totals.total, true) }}</time></div>
                </div>
                <div class="col">
                    <div class="text-secondary small">{{ 'Billable'|trans }}</div>
                    <div class="font-weight-medium text-success"><time>{{ format_interval(totals.billable, true) }}</time></div>
                </div>
            </div>
            <div style="height: 220px;">
                {{ render_chart(chart, {style: 'width: 100%; height: 100%;'}) }}
            </div>
        </div>
    </div>
</div>
