{% set initial_elapsed = entry
    ? entry.dateStart.diffAsCarbonInterval('now', true).cascade().format('%H:%I:%S')
    : '00:00:00'
%}
<div {{ attributes.defaults({id: 'time-tracker'}) }}>
    {{ form_start(form, {
        attr: {
            'data-action': 'live#action:prevent',
            'data-live-action-param': 'startTracker',
        },
    }) }}
        <div class="card p-0 shadow-lg mb-5 rounded">
            <div class="card-body p-0">
                <div class="row" id="time-tracker-fields">
                    <div class="col-7">
                        {{ form_widget(form.description, {'attr': {'class': 'border-0 form-control-lg'}}) }}
                    </div>
                    <div class="col-3" data-live-ignore
                         {{ stimulus_controller('time-tracker-form') }}
                         data-action="time-tracker:cleared@window->time-tracker-form#clear">
                        {{ form_widget(form.project, {'attr': {'class': 'border-0 form-control-lg'}}) }}
                    </div>
                    <div class="col-3" data-live-ignore
                         {{ stimulus_controller('time-tracker-form') }}
                         data-action="time-tracker:cleared@window->time-tracker-form#clear">
                        {{ form_widget(form.tags, {'attr': {'class': 'border-0 form-control-lg'}}) }}
                    </div>
                    <div class="col d-flex align-items-center" id="time-tracker-display" {{ stimulus_controller('time-tracker', {'time': entry.dateStart.timestampMs|default(0)}) }}>
                        <h2 class="m-0 p-0 me-2" {{ stimulus_target('time-tracker', 'timer') }} data-live-ignore>
                            <time>{{ initial_elapsed }}</time>
                        </h2>

                        {% set is_billable = form.billable.vars.checked %}
                        <div class="form-check form-switch p-0 m-0 me-2 d-flex align-items-center">
                            {{ form_widget(form.billable, {'attr': {'class': 'd-none'}}) }}
                            <label for="{{ form.billable.vars.id }}"
                                   class="m-0 p-0 border-0 bg-transparent text-{{ is_billable ? 'success' : 'muted' }}"
                                   style="cursor: pointer;"
                                   title="{{ (is_billable ? 'Billable' : 'Non-billable')|trans }}"
                                   aria-label="{{ (is_billable ? 'Billable' : 'Non-billable')|trans }}">
                                {{ ux_icon(is_billable ? 'tabler:currency-dollar' : 'tabler:currency-dollar-off', {width: '24px', height: '24px'}) }}
                            </label>
                        </div>

                        <button id="time-tracker-start" type="submit"
                                class="btn-link p-0 border-0 bg-transparent{% if entry %} d-none{% endif %}"
                                aria-label="{{ 'Start Tracker'|trans }}"
                                title="{{ 'Start Tracker'|trans }}">
                            {{ ux_icon('tabler:player-play-filled', {width: '32px', height: '32px', class: 'text-success'}) }}
                        </button>

                        <button id="time-tracker-stop" type="button"
                                class="btn-link p-0 border-0 bg-transparent{% if not entry %} d-none{% endif %}"
                                aria-label="{{ 'Stop Tracker'|trans }}"
                                title="{{ 'Stop Tracker'|trans }}"
                                data-action="live#action:prevent"
                                data-live-action-param="stopTimer">
                            {{ ux_icon('tabler:player-stop-filled', {width: '32px', height: '32px', class: 'text-danger'}) }}
                        </button>
                    </div>
                </div>
            </div>
        </div>
    {{ form_end(form) }}
</div>
