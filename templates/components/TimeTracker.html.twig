{% set initial_elapsed = entry
    ? entry.dateStart.diffAsCarbonInterval('now', true).cascade().format('%H:%I:%S')
    : '00:00:00'
%}
{% set is_running = entry is not null %}
{% set is_billable = form.billable.vars.checked %}

{# Resolve the selected Tag entities for the summary chip. Use the form's
   choice list (which always reflects the latest formValues snapshot) rather
   than entry.tags, which is null before Start. #}
{% set selected_tag_ids = form.tags.vars.value ?? [] %}
{% set selected_tags = [] %}
{% if selected_tag_ids|length > 0 %}
    {% for choice in form.tags.vars.choices %}
        {% if choice.value in selected_tag_ids %}
            {% set selected_tags = selected_tags|merge([choice.data]) %}
        {% endif %}
    {% endfor %}
{% endif %}
{% set tag_count = selected_tags|length %}

<div {{ attributes.defaults({id: 'time-tracker'}) }}>
    {{ form_start(form, {
        attr: {
            'data-action': 'live#action:prevent',
            'data-live-action-param': 'startTracker',
            'class': 'st-timer',
            'data-running': is_running ? '1' : '0',
        },
    }) }}

        {{ form_widget(form.description, {'attr': {'class': 'st-timer-desc', 'placeholder': 'What are you working on?'|trans}}) }}

        <div class="st-timer-cell project"
             data-live-ignore
             {{ stimulus_controller('time-tracker-form') }}
             data-action="time-tracker:cleared@window->time-tracker-form#clear">
            {{ form_widget(form.project) }}
        </div>

        {# Tags cell: single summary chip (icon + colored dots + truncated
           names). The real TomSelect input is hidden behind it and opened on
           click via the `tag-cell` controller. `data-live-ignore` is scoped to
           the input wrapper so the summary still morphs on tag changes. #}
        <div class="st-timer-cell tags{% if tag_count > 0 %} has-tags{% endif %}"
             {{ stimulus_controller('tag-cell time-tracker-form') }}
             data-action="time-tracker:cleared@window->time-tracker-form#clear click->tag-cell#open">
            <span class="ic">{{ ux_icon('tabler:tag', {'width': '18', 'height': '18'}) }}</span>
            {% if tag_count > 0 %}
                <span class="st-tags-summary">
                    <span class="st-tags-dots">
                        {% for tag in selected_tags %}
                            <span class="st-tag-dot" style="background-color: {{ tag.color }}"></span>
                        {% endfor %}
                    </span>
                    <span class="st-tags-summary-text">{% for tag in selected_tags %}{{ tag.name }}{% if not loop.last %}, {% endif %}{% endfor %}</span>
                </span>
            {% endif %}
            <div class="st-tags-input" data-live-ignore>
                {{ form_widget(form.tags) }}
            </div>
        </div>

        {# Use the default form theme for this field so the checkbox isn't
           wrapped in Bootstrap 5's `.form-check` div + duplicate label. #}
        {% form_theme form.billable 'form_div_layout.html.twig' %}
        <label for="{{ form.billable.vars.id }}"
               class="st-timer-cell billable{% if is_billable %} on{% endif %}"
               title="{{ (is_billable ? 'Billable' : 'Not billable')|trans }}">
            {{ form_widget(form.billable, {'attr': {'class': 'd-none'}}) }}
            $
        </label>

        <div class="st-timer-display"
             id="time-tracker-display"
             {{ stimulus_controller('time-tracker', {'time': entry.dateStart.timestampMs|default(0)}) }}>
            {% if is_running %}<span id="time-tracker-dot" class="live-dot"></span>{% endif %}
            <span id="time-tracker-timer" {{ stimulus_target('time-tracker', 'timer') }} data-live-ignore>{{ initial_elapsed }}</span>
        </div>

        {% if is_running %}
            <button type="button"
                    id="time-tracker-stop"
                    class="st-timer-start running"
                    aria-label="{{ 'Stop Tracker'|trans }}"
                    title="{{ 'Stop Tracker'|trans }}"
                    data-action="live#action:prevent"
                    data-live-action-param="stopTimer">
                <span class="ic">{{ ux_icon('tabler:player-stop-filled', {'width': '16', 'height': '16'}) }}</span>
                {{ 'Stop'|trans }}
            </button>
        {% else %}
            <button type="submit"
                    id="time-tracker-start"
                    class="st-timer-start"
                    aria-label="{{ 'Start Tracker'|trans }}"
                    title="{{ 'Start Tracker'|trans }}">
                <span class="ic">{{ ux_icon('tabler:player-play-filled', {'width': '16', 'height': '16'}) }}</span>
                {{ 'Start'|trans }}
            </button>
        {% endif %}

    {{ form_end(form) }}
</div>
