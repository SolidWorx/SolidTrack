<div {{ attributes }}>
    {% include 'components/_report_filters.html.twig' with {showGroupBy: true} %}

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 14px; margin-bottom: 18px;">
        <div class="st-card">
            <div class="st-card-body" style="padding: 16px 18px;">
                <div class="st-card-sub">{{ 'Total time'|trans }}</div>
                <div style="font-size: 22px; font-weight: 600;"><time>{{ format_interval(totals.total, true) }}</time></div>
                <div class="st-card-sub">{{ totals.entries }} {{ 'entries'|trans }}</div>
            </div>
        </div>
        <div class="st-card">
            <div class="st-card-body" style="padding: 16px 18px;">
                <div class="st-card-sub">{{ 'Billable'|trans }}</div>
                <div style="font-size: 22px; font-weight: 600; color: var(--st-primary, #4f46e5);">
                    <time>{{ format_interval(totals.billable, true) }}</time>
                </div>
            </div>
        </div>
        <div class="st-card">
            <div class="st-card-body" style="padding: 16px 18px;">
                <div class="st-card-sub">{{ 'Non-billable'|trans }}</div>
                <div style="font-size: 22px; font-weight: 600; color: #f59e0b;">
                    <time>{{ format_interval(totals.nonBillable, true) }}</time>
                </div>
            </div>
        </div>
        <div class="st-card">
            <div class="st-card-body" style="padding: 16px 18px;">
                <div class="st-card-sub">{{ 'Amount'|trans }}</div>
                <div style="font-size: 22px; font-weight: 600;">${{ totals.amount|number_format(2, '.', ',') }}</div>
            </div>
        </div>
    </div>

    <div class="st-card" style="margin-bottom: 18px;">
        <div class="st-card-body" style="padding: 14px 18px;">
            <div style="height: 220px;">
                {{ render_chart(chart, {style: 'width: 100%; height: 100%;'}) }}
            </div>
        </div>
    </div>

    <div class="st-card">
        <div class="st-card-head" style="padding: 14px 18px; border-bottom: 1px solid var(--st-border, #e5e7eb);">
            <h3 class="st-card-title">{{ 'Breakdown'|trans }}</h3>
        </div>
        <div class="table-responsive">
            <table class="table table-vcenter card-table">
                <thead>
                    <tr>
                        <th>{{ 'Name'|trans }}</th>
                        <th style="text-align: right;">{{ 'Total'|trans }}</th>
                        <th style="text-align: right;">{{ 'Billable'|trans }}</th>
                        <th style="text-align: right;">{{ 'Amount'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for group in groups %}
                        <tr style="font-weight: 600;">
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    {% if group.color %}
                                        <span style="display: inline-block; width: 10px; height: 10px; border-radius: 50%; background: {{ group.color }};"></span>
                                    {% endif %}
                                    <span>{{ group.label }}</span>
                                    {% if group.sub %}
                                        <span class="text-muted" style="font-weight: 400;">· {{ group.sub }}</span>
                                    {% endif %}
                                </div>
                            </td>
                            <td style="text-align: right;"><time>{{ group.totalHours|number_format(2) }}h</time></td>
                            <td style="text-align: right;"><time>{{ group.billableHours|number_format(2) }}h</time></td>
                            <td style="text-align: right;">${{ group.amount|number_format(2, '.', ',') }}</td>
                        </tr>
                        {% for child in group.children %}
                            <tr>
                                <td style="padding-left: 32px; color: var(--st-text-muted, #6b7280);">↳ {{ child.label }}</td>
                                <td style="text-align: right;">{{ child.totalHours|number_format(2) }}h</td>
                                <td style="text-align: right;">{{ child.billableHours|number_format(2) }}h</td>
                                <td style="text-align: right;">${{ child.amount|number_format(2, '.', ',') }}</td>
                            </tr>
                        {% endfor %}
                    {% else %}
                        <tr>
                            <td colspan="4" style="text-align: center; padding: 24px; color: var(--st-text-muted, #6b7280);">
                                {{ 'No time entries match the selected filters.'|trans }}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
