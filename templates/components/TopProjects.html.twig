<div {{ attributes }}>
    <div class="st-card">
        <div class="st-card-head">
            <div>
                <h3 class="st-card-title">{{ 'Top projects'|trans }}</h3>
                <div class="st-card-sub">
                    {{ 'This week'|trans }} ·
                    <time>{{ format_interval(topProjects.total, true) }}</time> {{ 'tracked'|trans }}
                </div>
            </div>
            <a href="#" class="st-card-link">{{ 'View all'|trans }}</a>
        </div>
        <div class="st-card-body">
            {% if topProjects.projects is empty %}
                <div style="padding: 12px 0; color: var(--st-text-muted); font-size: 13px; text-align: center;">
                    {{ 'No tracked time this week.'|trans }}
                </div>
            {% else %}
                <div class="st-project-bars">
                    {% for row in topProjects.projects %}
                        <div>
                            <div class="row-head">
                                <div class="name">
                                    <span class="st-pdot" style="background: {{ row.project.color }};"></span>
                                    <span>{{ row.project.name }}</span>
                                </div>
                                <span class="st-time" style="font-size: 13px;">
                                    <time>{{ format_interval(row.duration, true) }}</time>
                                </span>
                            </div>
                            <div class="track" role="progressbar"
                                 aria-valuenow="{{ row.percent|number_format(0) }}"
                                 aria-valuemin="0" aria-valuemax="100"
                                 aria-label="{{ row.project.name }} share">
                                <div style="width: {{ row.percent }}%; background: {{ row.project.color }};"></div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
</div>
