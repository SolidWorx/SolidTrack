<div {{ attributes }}>
    <div class="card">
        <div class="card-header py-2">
            <h3 class="card-title">{{ 'Top Projects'|trans }}</h3>
            <div class="card-actions">
                <small class="text-secondary">
                    {{ 'Total:'|trans }} <time>{{ format_interval(topProjects.total, true) }}</time>
                </small>
            </div>
        </div>
        <div class="list-group list-group-flush">
            {% for row in topProjects.projects %}
                <div class="list-group-item">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <span class="d-inline-block rounded-circle align-middle"
                                  style="width: 12px; height: 12px; background-color: {{ row.project.color }};"
                                  aria-label="{{ row.project.color }}"></span>
                        </div>
                        <div class="col text-truncate">
                            <span class="text-body d-block text-truncate">{{ row.project.name }}</span>
                            <small class="text-secondary">{{ row.project.client }}</small>
                        </div>
                        <div class="col-auto text-end">
                            <div class="font-weight-medium"><time>{{ format_interval(row.duration, true) }}</time></div>
                            <small class="text-secondary">{{ row.percent|number_format(0) }}%</small>
                        </div>
                    </div>
                    <div class="progress progress-sm mt-2">
                        <div class="progress-bar"
                             style="width: {{ row.percent }}%; background-color: {{ row.project.color }};"
                             role="progressbar"
                             aria-valuenow="{{ row.percent|number_format(0) }}"
                             aria-valuemin="0"
                             aria-valuemax="100"
                             aria-label="{{ row.project.name }} share"></div>
                    </div>
                </div>
            {% else %}
                <div class="list-group-item text-secondary text-center py-4">
                    {{ 'No tracked time this week.'|trans }}
                </div>
            {% endfor %}
        </div>
    </div>
</div>
