{% extends 'layouts/base.html.twig' %}

{% set hour = 'now'|date('G') %}
{% set greeting = hour < 12 ? 'Good morning'|trans : (hour < 18 ? 'Good afternoon'|trans : 'Good evening'|trans) %}
{% set display_name = app.user.firstName ?: (app.user.email|split('@')|first) %}

{% block page_header %}
    <div class="page-header">
        <div class="container-xl">
            <section class="st-pagehead">
                <div>
                    <h1 class="st-pagehead-title">{{ greeting }}, {{ display_name }}</h1>
                    <p class="st-pagehead-sub">{{ 'now'|date('l, F j, Y') }}</p>
                </div>
                <div class="st-pagehead-actions">
                    <button type="button" class="st-btn st-btn-outline">
                        <span class="ic">{{ ux_icon('tabler:calendar', {'width': '14', 'height': '14'}) }}</span>
                        {{ 'This week'|trans }}
                    </button>
                    <button type="button" class="st-btn st-btn-outline">
                        <span class="ic">{{ ux_icon('tabler:download', {'width': '14', 'height': '14'}) }}</span>
                        {{ 'Export'|trans }}
                    </button>
                    <span class="st-vsep"></span>
                    <a href="#" class="st-btn st-btn-primary" data-bs-toggle="modal" data-bs-target="#modal-report">
                        <span class="ic">{{ ux_icon('tabler:plus', {'width': '14', 'height': '14'}) }}</span>
                        {{ 'New entry'|trans }}
                    </a>
                </div>
            </section>
        </div>
    </div>
{% endblock %}

{% block content %}
    <twig:TimeTracker />

    <div style="margin-top: 18px;">
        <twig:DashboardStats />
    </div>

    <div style="display: grid; grid-template-columns: minmax(0, 1fr) 360px; gap: 18px; margin-top: 18px;">
        <div>
            <twig:UserActivity />
        </div>
        <div style="display: flex; flex-direction: column; gap: 14px;">
            <twig:WeeklyChart />
            <twig:TopProjects />
            <twig:BillableSplit />
        </div>
    </div>
{% endblock content %}
