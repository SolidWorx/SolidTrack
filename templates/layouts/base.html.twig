{% extends '@Ui/Layout/base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('app') }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
{% endblock stylesheets %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('app') }}
{% endblock javascripts %}

{% block body %}
    <div class="page" data-controller="auto-select">
        {% include 'layouts/_partial/left_menu.html.twig' %}

        {% include 'layouts/_partial/top_nav.html.twig' %}

        <div class="page-wrapper">
            {% for label, messages in app.flashes %}
                <div class="container-xl mt-4">
                    {% for message in messages %}
                        <twig:Ui:Alert type="{{ label }}" dismissable>
                            {{ message|trans }}
                        </twig:Ui:Alert>
                    {% endfor %}
                </div>
            {% endfor %}

            {% block page_header %}{% endblock page_header %}

            <div class="page-body">
                <div class="container-xl d-flex flex-column justify-content-center">
                    {% block content %}{% endblock content %}
                </div>
            </div>

            <footer class="footer footer-transparent d-print-none">
                <div class="container-xl">
                    <div class="row text-center align-items-center flex-row-reverse">
                        <div class="col-lg-auto ms-lg-auto">
                            <ul class="list-inline list-inline-dots mb-0">
                                <li class="list-inline-item"><a href="https://tabler.io/docs" target="_blank" class="link-secondary" rel="noopener">Documentation</a></li>
                                <li class="list-inline-item">
                                    <a href="https://github.com/SolidWorx/SoldTrack" target="_blank" class="link-secondary" rel="noopener">
                                        {{ ux_icon('tabler:brand-github') }}
                                        Source code
                                    </a>
                                </li>
                                <li class="list-inline-item">
                                    <a href="https://github.com/sponsors/solidinvoice" target="_blank" class="link-secondary" rel="noopener">
                                        {{ ux_icon('tabler:heart') }}
                                        Sponsor
                                    </a>
                                </li>
                            </ul>
                        </div>
                        <div class="col-12 col-lg-auto mt-3 mt-lg-0">
                            <ul class="list-inline list-inline-dots mb-0">
                                <li class="list-inline-item">
                                    Copyright &copy; {{ 'now'|date('Y') }}
                                    <a href="https://solidworx.co" class="link-secondary">SolidWorx</a>.
                                    All rights reserved.
                                </li>
                                <li class="list-inline-item">
                                    v{{ constant('App\\Kernel::APP_VERSION') }}
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </div>
{% endblock body %}
